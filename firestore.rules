rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Family documents
    match /families/{familyId} {
      // Any authenticated user can read families (needed for child login by code).
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isFamilyParent(familyId);

      // Login profiles — readable by any auth user (needed for child login),
      // writable only by the family's parent
      match /loginProfiles/{profileId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAuthenticated() && isFamilyParent(familyId);
      }
    }

    // User documents — restricted to family members only
    match /users/{userId} {
      // Single-doc read: owner, parent in same family, or child with matching lastAuthUid
      allow get: if isAuthenticated() && canAccessUser(userId);
      // Collection query: parent can list users in their own family
      allow list: if isAuthenticated() && isParentReadingOwnFamily();

      // A user can create their own doc (registration)
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Parents can create child docs in their family
      allow create: if isAuthenticated() && isParent();

      // Allow anonymous login stamp: only anonymous users can set lastAuthUid or fcmTokens on a child.
      // TODO: Move to Cloud Function for proper PIN verification server-side.
      allow update: if isAuthenticated()
        && request.auth.token.firebase.sign_in_provider == 'anonymous'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastAuthUid', 'fcmTokens'])
        && resource.data.role == 'child';

      // Parents can update users in their family
      allow update: if isAuthenticated() && isParentInSameFamily(userId);
      // A user can update their own doc (parent or child with matching lastAuthUid)
      allow update: if isAuthenticated() && canAccessUser(userId);

      // Transactions subcollection — restricted to owner/parent, validated writes
      match /transactions/{txId} {
        allow read: if isAuthenticated() && canAccessUser(userId);
        allow create: if isAuthenticated() && canAccessUser(userId)
          && request.resource.data.amount is number
          && request.resource.data.amount > 0;
        // Parents can update description/note but NOT amount (prevents balance drift)
        allow update: if isAuthenticated() && isParentInSameFamily(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['amount', 'balanceAfter', 'type', 'createdAt']);
        allow delete: if isAuthenticated() && isParentInSameFamily(userId);
      }

      // Allowances subcollection — parents can manage, owner/parent can read
      match /allowances/{allowanceId} {
        allow read: if isAuthenticated() && canAccessUser(userId);
        allow create, update, delete: if isAuthenticated() && isParentInSameFamily(userId);
      }

      // Savings subcollection — restricted to owner/parent, validated writes
      match /savings/{savingsId} {
        allow read: if isAuthenticated() && canAccessUser(userId);
        allow create: if isAuthenticated() && canAccessUser(userId)
          && request.resource.data.currentAmount is number
          && request.resource.data.currentAmount >= 0;
        allow update: if isAuthenticated() && canAccessUser(userId)
          && request.resource.data.currentAmount is number
          && request.resource.data.currentAmount >= 0;
        allow delete: if isAuthenticated() && canAccessUser(userId);
      }
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isParent() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent';
    }

    function isFamilyParent(familyId) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return user.data.familyId == familyId && user.data.role == 'parent';
    }

    function isParentInSameFamily(targetUserId) {
      let requester = get(/databases/$(database)/documents/users/$(request.auth.uid));
      let target = get(/databases/$(database)/documents/users/$(targetUserId));
      return requester.data.role == 'parent' && requester.data.familyId == target.data.familyId;
    }

    function isParentReadingOwnFamily() {
      let requester = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return requester.data.role == 'parent'
        && resource.data.familyId == requester.data.familyId;
    }

    function canAccessUser(targetUserId) {
      let target = get(/databases/$(database)/documents/users/$(targetUserId));
      return request.auth.uid == targetUserId
        || isParentInSameFamily(targetUserId)
        || target.data.lastAuthUid == request.auth.uid;
    }
  }
}
